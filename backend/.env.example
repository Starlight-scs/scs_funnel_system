DJANGO_SECRET_KEY=replace-with-a-real-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,api.unlockthenextstep.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.unlockthenextstep.com,https://unlockthenextstep.com,https://www.unlockthenextstep.com
DJANGO_CORS_ALLOWED_ORIGINS=https://unlockthenextstep.com,https://www.unlockthenextstep.com
DATABASE_URL=postgresql://username:password@hostname:5432/database_name
DB_SSLMODE=require
DB_CONN_MAX_AGE=60
DJANGO_SECURE_SSL_REDIRECT=True
UPLOADTHING_TOKEN=replace-with-your-uploadthing-token
