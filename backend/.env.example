DJANGO_SECRET_KEY=replace-with-a-real-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,your-backend-domain.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-backend-domain.onrender.com,https://your-frontend-domain.vercel.app
DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app
DATABASE_URL=postgresql://username:password@hostname:5432/database_name
DB_SSLMODE=require
DB_CONN_MAX_AGE=60
DJANGO_SECURE_SSL_REDIRECT=True
UPLOADTHING_TOKEN=replace-with-your-uploadthing-token
